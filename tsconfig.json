{
  "compilerOptions": {
    "strict": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "jsx": "react",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "baseUrl": "./",
    "paths": {
      "@@/*": [".dumi/tmp/*"],
      "lyrixi-mobile": ["src"],
      "lyrixi-mobile/*": ["src/*", "*"]
    }
  },
  "include": [".dumirc.ts", ".fatherrc.ts", "src"]
}
