    "disabled": "boolean | undefined",
    "allowClear": "boolean | undefined",
    "autoFocus": "boolean | undefined",
    "autoSelect": "boolean | undefined",
    "enableCompositionEnd": "boolean | undefined — 输入法落字后再触发 onChange",
    "style": "CSSProperties | undefined",
    "className": "string | undefined",
    "inputRender": "(props) => ReactNode | undefined — 自定义 input",
    "rightIconNode": "ReactNode | undefined",
    "clearRender": "ReactNode | ((props) => ReactNode) | undefined",
    "precision": "number | undefined",
    "trim": "boolean | undefined",
    "max": "number | undefined",
    "min": "number | undefined",
    "maxLength": "number | undefined",
    "inputMode": "string | undefined",
    "onClick": "(e) => void | undefined",
    "onChange": "(value, meta) => void | undefined",
    "onBlur": "(e) => void | undefined",
    "onFocus": "(e) => void | undefined",
    "onKeyDown": "(e) => void | undefined",
    "onPressEnter": "(e) => void | undefined",
    "onSearch": "(keyword) => void | undefined"
  },
  "ToolBar.SearchActive": {
    "value": "string | undefined — 当前搜索值",
    "placeholder": "string | undefined",
    "allowClear": "boolean | undefined",
    "autoSelect": "boolean | undefined",
    "enableCompositionEnd": "boolean | undefined",
    "style": "CSSProperties | undefined",
    "className": "string | undefined",
    "onChange": "(value, meta) => void | undefined",
    "onSearch": "(keyword) => void | undefined",
    "onCancel": "() => void | undefined",
    "onBlur": "(e) => void | undefined",
    "onFocus": "(e) => void | undefined"
  },
  "ToolBar.Filter": {
    "direction": "string | undefined — 透传给内部 Button 的排布方向",
    "block": "boolean | undefined",
    "color": "string | undefined — 默认 default；激活态场景常传 primary",
    "backgroundColor": "string | undefined",
    "borderColor": "string | undefined — 默认 default",
    "border": "string | undefined — 默认 none",
    "size": "string | undefined",
    "sizeEqual": "boolean | undefined",
    "fontSize": "string | number | undefined",
    "radius": "string | undefined — 默认 m",
    "style": "CSSProperties | undefined",
    "className": "string | undefined",
    "maskStyle": "CSSProperties | undefined",
    "maskClassName": "string | undefined",
    "modalStyle": "CSSProperties | undefined",
    "modalClassName": "string | undefined",
    "children": "ReactNode | undefined — 默认按钮内容；不传时显示筛选图标",
    "comboRender": "(props: { comboRef; open; onClick }) => ReactNode | undefined — 自定义触发器",
    "modalRender": "(props: { open; onClose }) => ReactNode | undefined — 弹层主体",
    "footerRender": "(props: { onClose }) => ReactNode | undefined — 弹层底部",
    "portal": "HTMLElement | undefined — 弹层挂载点",
    "onCancel": "() => void | undefined",
    "onOpen": "() => void | undefined",
    "onClose": "() => void | undefined"
  },
  "ToolBar.Filter.ref": {
    "element": "HTMLElement | null — 触发按钮 DOM",
    "getElement": "() => HTMLElement | null",
    "open": "() => void",
    "close": "() => void"
  }
