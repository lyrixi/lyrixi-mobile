{
  "_comment": "通用页初始化 DSL：描述展示层（Page.Header / Page.Main / Page.Footer）与请求/数据处理层骨架。知识库入口：ai/knowledge/components/Page。后续步骤可在本文件上扩展 ToolBar、Form、FooterBar 等表现；转译时页面上的业务变量可先保留占位不绑定真实值。",
  "meta": {
    "pageId": "",
    "title": ""
  },
  "knowledge": {
    "page": "ai/knowledge/components/Page",
    "pagePropsRef": "ai/knowledge/components/Page/Page-props.json",
    "pageRulesRef": "ai/knowledge/components/Page/Page-rules.md"
  },
  "presentation": {
    "root": "Page",
    "regions": [
      {
        "slot": "Header",
        "component": "Page.Header",
        "description": "顶区：后续可挂 NavBar、ToolBar 等；本阶段可为空占位。",
        "childrenPlaceholder": null
      },
      {
        "slot": "Main",
        "component": "Page.Main",
        "description": "主内容区：后续可挂 Card、Form、列表等；本阶段可为空占位。",
        "childrenPlaceholder": null
      },
      {
        "slot": "Footer",
        "component": "Page.Footer",
        "description": "底区：后续可挂 FooterBar 等；本阶段可为空占位。",
        "childrenPlaceholder": null
      }
    ]
  },
  "api": {
    "_comment": "与 src/examples/Detail/demos/Form/api 同构：按模块拆文件，经 api/index 汇总导出。",
    "entry": "api/index.ts",
    "modules": {
      "queryData": {
        "file": "api/queryData/index.ts",
        "role": "首屏/详情加载",
        "runtime": {
          "uses": ["Device", "Loading", "LocaleUtil", "ObjectUtil", "Request"],
          "url": "",
          "method": "POST",
          "headers": {
            "content-type": "application/json"
          },
          "payload": {
            "idParam": "id",
            "idSource": "Device.getUrlParameter('id')"
          },
          "response": {
            "successCode": "1",
            "dataPath": "data",
            "emptyMessageKey": "暂无数据",
            "errorMessageKey": "获取数据错误！",
            "exceptionMessageKey": "获取数据异常！"
          }
        },
        "returnShape": {
          "data": "Record<string, unknown> | 业务详情对象",
          "status": "'empty' | '500' 等，与 Result 联用",
          "message": "string"
        }
      },
      "approveData": {
        "file": "api/approveData/index.ts",
        "role": "保存/提交/审批等写操作",
        "runtime": {
          "uses": ["Device", "Loading", "LocaleUtil", "Request"],
          "url": "",
          "method": "POST",
          "headers": {
            "content-type": "application/json"
          },
          "payload": {
            "idFromUrl": "Device.getUrlParameter('id')",
            "extra": {}
          },
          "response": {
            "successCodes": ["1", "2"],
            "note": "code '2' 常表示防重复等业务语义，见 Form 示例"
          }
        }
      }
    }
  },
  "dataLayer": {
    "_comment": "页面状态与转译变量：生成代码时可先声明、占位，不强制赋值，供下一步 DSL 挂 ToolBar/Form/FooterBar。",
    "pageState": {
      "result": {
        "type": "unknown | null",
        "description": "全屏态：{ data?, status?, message? }，与 queryData 返回对齐"
      },
      "tokenRef": {
        "type": "string",
        "description": "防重复提交等，可选，与 Form 示例 tokenRef 同语义"
      },
      "queryParams": {
        "type": "Record<string, unknown>",
        "description": "列表/筛选等扩展用，可与 payloadMap 结合"
      }
    },
    "viewBindings": {
      "header": null,
      "main": null,
      "footer": null,
      "_comment": "null 表示下一步 DSL 再填充；可改为 { component, propsRef } 结构"
    },
    "httpDefaults": {
      "url": "",
      "method": "POST",
      "contentType": "json",
      "requestDefaults": {},
      "responseMap": {
        "successCode": "1",
        "messagePath": "message"
      }
    }
  },
  "nextDsl": {
    "_comment": "后续增量：在保留本 init 架构的前提下增加控件与绑定。",
    "suggestedComponents": [
      "ToolBar",
      "Form",
      "FooterBar",
      "NavBar"
    ],
    "knowledgeRoots": [
      "ai/knowledge/components/ToolBar",
      "ai/knowledge/components/Form",
      "ai/knowledge/components/FooterBar"
    ]
  }
}
