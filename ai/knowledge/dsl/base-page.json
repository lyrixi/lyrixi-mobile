{
  "example": "ai/knowledge/examples/BasePage",
  "description": "用于详情、编辑、新增页面生成, 包含请求/数据处理层骨架。从本文件生成/改写同构页时，按 ai/knowledge/skills/base-page-dsl.md 中流程执行。",
  "path": "src/examples/Test",
  "api": {
    "queryData": {
      "url": "/api/examples/queryData.do",
      "method": "POST",
      "headers": {
        "content-type": "application/json"
      },
      "payload": {
        "id": "Device.getUrlParameter('id')",
        "keyword": "queryParams.keyword"
      },
      "response": {
        "code转成result.status": "1:成功;其它:失败",
        "rows转成result.data<Array<Record<string, unknown>>": [
          {
            "idStr": "转成id字段",
            "nameStr": "转成name字段",
            "introduce": "转成description字段",
            "createTime": "转成description字段",
            "updateTime": "转成description字段"
          }
        ],
        "errMsg转成result.message": "获取数据成功"
      }
    }
  },
  "view": {
    "Header": {
      "SearchBar": {
        "placeholder": "按名称/拼音/拼音首字母查询",
        "value": "queryParams?.keyword"
      }
    },
    "Main": {},
    "Footer": {},
    "Skeleton": {}
  }
}
