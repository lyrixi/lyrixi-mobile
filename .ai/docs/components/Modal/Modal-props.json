{
  "Modal": {
    "open": "`boolean` — 是否显示",
    "maskClosable": "`boolean` — 点击遮罩关闭，默认 `true`",
    "safeArea": "`boolean` — 是否安全区，默认 `true`",
    "animation": "`'none' \\ | 'slideLeft' \\ | 'slideRight' \\ | 'slideUp' \\ | 'slideDown' \\ | 'zoom' \\ | 'fade'` — 动画效果，默认 `'zoom'`",
    "modalStyle": "`object` — 模态框样式",
    "modalClassName": "`string` — 模态框类名",
    "maskStyle": "`object` — 遮罩样式",
    "maskClassName": "`string` — 遮罩类名",
    "portal": "`HTMLElement \\ | null \\ | false` — 挂载节点",
    "children": "`ReactNode` — 模态框内容",
    "onClose": "`(e: Event) => void` — 关闭事件"
  },
  "Modal.ref": {
    "maskElement": "`HTMLDivElement` — 遮罩元素",
    "getMaskElement": "() => `HTMLDivElement` — 获取遮罩元素",
    "modalElement": "`HTMLDivElement` — 模态框元素",
    "getModalElement": "() => `HTMLDivElement` — 获取模态框元素"
  }
}
