{
  "MediaUploader": {
    "mediaType": "`Array<'image' \\ | 'video'>` — 媒体类型，默认 `['image']`",
    "list": "`Array<{fileThumbnail: string, fileUrl: string, filePath: string, status: 'choose' \\ | 'uploading' \\ | 'error' \\ | 'success'}>` — 媒体列表，默认 `[]`",
    "maxUploadCount": "`number` — 最大上传数量",
    "maxChooseCount": "`number` — 最大选择数量",
    "platform": "`'browser' \\ | 'wechatMiniProgram' \\ | 'wechat' \\ | 'wecom' \\ | 'wecomMiniProgram' \\ | 'dingtalk'` — 强制上传平台",
    "ellipsis": "`object` — 省略配置",
    "sourceType": "`Array<'album' \\ | 'camera'>` — 来源类型，默认 `['album', 'camera']`",
    "sizeType": "`Array<'original' \\ | 'compressed'>` — 尺寸类型，默认 `['compressed']`",
    "isSaveToAlbum": "`number` — 是否保存到本地，默认 `0`",
    "fileImageCompress": "`{maxWidth: number, quality: number}` — 图片压缩配置",
    "async": "`boolean` — 是否异步上传，默认 `false`",
    "verifyImage": "`boolean` — 校验图片，默认 `true`",
    "reUpload": "`boolean` — 支持重新上传，默认 `true`",
    "allowClear": "`boolean` — 允许清除，默认 `true`",
    "allowChoose": "`boolean` — 允许选择，默认 `true`",
    "previewAllowChoose": "`boolean` — 预览允许选择",
    "previewAllowClear": "`boolean` — 预览允许清除",
    "compatible": "`boolean` — 兼容模式，默认 `true`",
    "timeout": "`number` — 超时时间",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "uploadPosition": "`'start' \\ | 'end'` — 上传位置",
    "previewSafeArea": "`boolean` — 预览安全区",
    "previewNavBarStyle": "`object` — 预览导航栏样式",
    "previewNavBarClassName": "`string` — 预览导航栏类名",
    "previewModalStyle": "`object` — 预览模态框样式",
    "previewModalClassName": "`string` — 预览模态框类名",
    "previewMaskStyle": "`object` — 预览遮罩样式",
    "previewMaskClassName": "`string` — 预览遮罩类名",
    "uploadRender": "`() => ReactNode` — 上传按钮渲染",
    "uploadingRender": "`(item: object) => ReactNode` — 上传中渲染",
    "itemRender": "`(item: object) => ReactNode` — 项渲染",
    "previewPortal": "`HTMLElement` — 预览挂载节点",
    "previewCancelPosition": "`string` — 预览取消位置",
    "getItemExtra": "`(options: object) => object` — 获取项额外数据",
    "getUploadUrl": "`(options: object) => string` — 获取上传地址",
    "formatChoose": "`(result: object) => object` — 格式化选择",
    "formatHeaders": "`(options: object) => object` — 格式化请求头",
    "formatPayload": "`(options: object) => object` — 格式化请求体",
    "formatResponse": "`(result: object) => object` — 格式化响应",
    "onBeforeChoose": "`(e: Event) => Promise<boolean>` — 选择前事件",
    "onUpload": "`(item: object) => Promise<object>` — 上传事件",
    "onChange": "`(list: Array, options: object) => void` — 变化事件",
    "onPreview": "`(item: object, index: number) => void` — 预览事件"
  },
  "MediaUploader.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素"
  }
}
