{
  "Selector": {
    "value": "`any[]` — 选中的值",
    "list": "`Array<{id: string, name: string, [key: string]: any}>` — 选项列表",
    "ellipsis": "`object` — 省略配置",
    "disabled": "`boolean` — 是否禁用",
    "multiple": "`boolean` — 是否多选",
    "allowClear": "`boolean` — 允许清除",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "columns": "`number` — 列数，默认 `2`",
    "id": "`string` — 选择组 ID",
    "onChange": "`(value: any[]) => void` — 变化事件"
  },
  "Selector.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "instance": "`object` — 实例对象",
    "getElement": "() => `HTMLDivElement` — 获取根元素",
    "getInstance": "() => `object` — 获取实例对象"
  }
}
