{
  "Switch": {
    "checked": "`boolean` — 是否选中",
    "readOnly": "`boolean` — 是否只读",
    "disabled": "`boolean` — 是否禁用",
    "size": "`'xxs' \\ | 'xs' \\ | 's' \\ | 'm' \\ | 'l' \\ | 'xl'` — 尺寸，默认 `'m'`",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "on": "`ReactNode` — 开启状态内容",
    "off": "`ReactNode` — 关闭状态内容",
    "onChange": "`(checked: boolean) => void` — 变化事件"
  },
  "Switch.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素"
  }
}
