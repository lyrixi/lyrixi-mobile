{
  "Form": {
    "layout": "`'horizontal' \\ | 'vertical' \\ | 'inline'` — 布局方式，默认 `'horizontal'`",
    "labelCol": "`object` — 标签列配置",
    "mainCol": "`object` — 内容列配置",
    "scrollerElement": "`HTMLElement` — 滚动容器元素",
