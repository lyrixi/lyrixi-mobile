{
  "Tooltip": {
    "maskClosable": "`boolean` — 点击遮罩关闭，默认 `true`",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "animation": "`'none' \\ | 'slideLeft' \\ | 'slideRight' \\ | 'slideUp' \\ | 'slideDown' \\ | 'zoom' \\ | 'fade' \\ | 'slideDownLeft'` — 动画效果，默认 `'slideDownLeft'`",
    "modalStyle": "`object` — 模态框样式",
    "modalClassName": "`string` — 模态框类名",
    "maskStyle": "`object` — 遮罩样式",
    "maskClassName": "`string` — 遮罩类名",
    "children": "`ReactNode` — 触发元素",
    "comboRender": "`() => ReactNode` — 自定义组合渲染",
    "modalRender": "`() => ReactNode` — 自定义模态框渲染",
    "referenceElement": "`HTMLElement \\ | (() => HTMLElement)` — 参考元素",
    "portal": "`HTMLElement \\ | null \\ | false` — 挂载节点",
    "onBeforeOpen": "`() => Promise<boolean>` — 打开前事件",
    "onOpen": "`() => void` — 打开事件",
    "onClose": "`() => void` — 关闭事件"
  },
  "Tooltip.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素"
  }
}
