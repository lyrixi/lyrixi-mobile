{
  "Picker": {
    "value": "`any \\ | any[]` — 选中的值",
    "placeholder": "`string` — 占位符",
    "formatter": "`(value: any) => string` — 格式化函数",
    "autoSize": "`boolean` — 自动调整大小",
    "separator": "`string` — 分隔符",
    "mode": "`string` — 模式",
    "readOnly": "`boolean` — 是否只读",
    "disabled": "`boolean` — 是否禁用",
    "allowClear": "`boolean` — 允许清除",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "leftIconNode": "`ReactNode` — 左侧图标",
    "rightIconNode": "`ReactNode` — 右侧图标",
    "clearRender": "`(props: object) => ReactNode` — 清除按钮渲染",
    "list": "`Array<object>` — 选项列表",
    "maskClosable": "`boolean` — 点击遮罩关闭",
    "safeArea": "`boolean` — 是否安全区",
    "modalStyle": "`object` — 模态框样式",
    "modalClassName": "`string` — 模态框类名",
    "maskStyle": "`object` — 遮罩样式",
    "maskClassName": "`string` — 遮罩类名",
    "portal": "`HTMLElement \\ | null \\ | false` — 挂载节点",
    "title": "`ReactNode` — 标题",
    "okNode": "`ReactNode` — 确认按钮",
    "cancelNode": "`ReactNode` — 取消按钮",
    "okVisible": "`boolean` — 确认按钮可见",
    "cancelVisible": "`boolean` — 取消按钮可见",
    "onBeforeOpen": "`() => Promise<boolean>` — 打开前事件",
    "onChange": "`(value: any \\ | any[]) => void` — 变化事件"
  },
  "Picker.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素",
    "close": "`() => void` — 关闭选择器",
    "open": "`() => void` — 打开选择器"
  }
}
