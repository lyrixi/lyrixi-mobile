{
  "ListAsync": {
    "cacheName": "`string` — 缓存名称",
    "url": "`string` — 数据接口地址",
    "headers": "`object` — 请求头",
    "payload": "`{rows: number, [key: string]: any}` — 查询参数",
    "formatPayload": "`(result: object) => object` — 格式化入参",
    "formatResult": "`(result: object) => object{status: 'error/success', totalPage: 总页数(非必返回), list: [列表数据]}` — 格式化结果",
    "formatViewList": "`(list: Array) => Array` — 格式化列表",
    "formatViewItem": "`(item: object) => object` — 格式化项",
    "errorRetry": "`boolean` — 错误重试",
    "emptyRetry": "`boolean` — 空状态重试",
    "multiple": "`boolean` — 是否多选",
    "allowClear": "`boolean` — 允许清除",
    "checkable": "`boolean` — 是否可选",
    "disableTopRefresh": "`boolean` — 禁用顶部刷新",
    "disableBottomRefresh": "`boolean` — 禁用底部刷新",
    "virtual": "`boolean` — 是否虚拟滚动",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "itemRender": "`(item: object) => ReactNode` — 自定义项渲染",
    "itemLayout": "`string` — 项布局",
    "loadingRender": "`() => ReactNode` — 加载中渲染",
    "prependRender": "`() => ReactNode` — 前置渲染",
    "appendRender": "`() => ReactNode` — 后置渲染",
    "onChange": "`(value: any \\ | any[]) => void` — 变化事件",
    "onScroll": "`(e: Event) => void` — 滚动事件",
    "onScrollEnd": "`(e: Event) => void` — 滚动结束事件",
    "onLoad": "`({result: object, action: string}) => void` — 加载事件"
  },
  "ListAsync.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素",
    "updateCache": "`(extraCache: object) => void` | - — 更新缓存",
    "clearCache": "`() => void` — 清除缓存",
    "getCache": "`() => object` — 获取缓存",
    "reload": "`(action?: string) => void` | - — 重新加载",
    "getResult": "`() => object` — 获取结果"
  }
}
