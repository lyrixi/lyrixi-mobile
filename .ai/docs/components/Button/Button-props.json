{
  "Button": {
    "id": "`string` — 按钮 ID",
    "direction": "`'horizontal' \\ | 'vertical'` — 方向，默认 `'horizontal'`",
    "block": "`boolean` — 是否为块级元素",
    "color": "`'default' \\ | 'transparent' \\ | 'primary' \\ | 'info' \\ | 'warning' \\ | 'danger' \\ | 'success'` — 颜色，默认 `'default'`",
    "backgroundColor": "`'default' \\ | 'transparent' \\ | 'white' \\ | 'primary' \\ | 'info' \\ | 'warning' \\ | 'danger' \\ | 'success'` — 背景颜色，默认 `'white'`",
    "borderColor": "`'default' \\ | 'transparent' \\ | 'primary' \\ | 'info' \\ | 'warning' \\ | 'danger' \\ | 'success'` — 边框颜色，默认 `'default'`",
    "border": "`'none' \\ | 'dotted' \\ | 'dashed' \\ | 'solid'` — 边框样式，默认 `'solid'`",
    "size": "`'xxs' \\ | 'xs' \\ | 's' \\ | 'm' \\ | 'l' \\ | 'xl' \\ | [number, number]` — 高度尺寸",
    "sizeEqual": "`boolean` — 是否为等宽高",
    "fontSize": "`'xxs' \\ | 'xs' \\ | 's' \\ | 'm' \\ | 'l' \\ | 'xl'` — 字体大小",
    "radius": "`'xxs' \\ | 'xs' \\ | 's' \\ | 'm' \\ | 'l' \\ | 'xl'` — 圆角",
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "disabled": "`boolean` — 是否禁用",
    "children": "`ReactNode` — 按钮内容",
    "onClick": "`(e: Event) => void` — 点击事件"
  },
  "Button.Text": {
    "style": "`object` — 自定义样式",
    "className": "`string` — 自定义类名",
    "children": "`ReactNode` — 文本内容"
  },
  "Button.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素"
  },
  "Button.Text.ref": {
    "element": "`HTMLDivElement` — 根元素",
    "getElement": "() => `HTMLDivElement` — 获取根元素"
  }
}
